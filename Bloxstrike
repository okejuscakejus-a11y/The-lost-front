local function isPlayerLookingAtTarget(player, targetPosition)
    local character = player.Character
    if not character then return false end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local camPos = Camera.CFrame.Position
    local lookVector = Camera.CFrame.LookVector
    local dir = (targetPosition - camPos).Unit
    return lookVector:Dot(dir) > 0.8
end

local function UpdateSpectatorList()
    if not Settings.SpectatorList or not SpectatorListText then return end
    if tick() - lastUpdateTime < 0.5 then return end
    lastUpdateTime = tick()
    local myPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myPos then
        SpectatorListText.Visible = false
        return
    end
    myPos = myPos.Position
    local spectators = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and isPlayerLookingAtTarget(player, myPos) then
                table.insert(spectators, player.Name)
            end
        end
    end
    local function listEquals(t1, t2)
        if #t1 ~= #t2 then return false end
        for i = 1, #t1 do
            if t1[i] ~= t2[i] then return false end
        end
        return true
    end
    if not listEquals(spectators, previousSpectators) then
        previousSpectators = spectators
        if #spectators == 0 then
            SpectatorListText.Text = L("Spectators") .. " None"
        else
            SpectatorListText.Text = L("Spectators") .. " " .. table.concat(spectators, ", ")
        end
    end
    SpectatorListText.Visible = true
end

