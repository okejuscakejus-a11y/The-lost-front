local function UpdateESP()
    if not Settings.ESPEnabled then ClearAllESP(); return end
    local myRoot = LocalPlayer.Character and (LocalPlayer.Character:FindFirstChild("HumanoidRootPart") or LocalPlayer.Character:FindFirstChild("Torso"))
    local color = Settings.ESPColor
    for plr, objs in pairs(ESPObjects) do
        local c = plr.Character
        local hum = c and c:FindFirstChildOfClass("Humanoid")
        local isEnemy = ShouldApplyToPlayer(plr)
        if not c or not hum or hum.Health <= 0 or not isEnemy then
            for _,obj in pairs(objs) do if obj and obj.Visible ~= nil then obj.Visible = false end end
        else
            local root = c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso") or c:FindFirstChild("UpperTorso")
            local head = c:FindFirstChild("Head") or c:FindFirstChild("Torso")
            if root and head then
                if myRoot and (myRoot.Position - root.Position).Magnitude <= Settings.ESPMaxDistance then
                    local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.6,0))
                    local rootPos = Camera:WorldToViewportPoint(root.Position)
                    local legPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0,3.5,0))
                    if rootPos.Z >= 0 then
                        local rV = Vector2.new(rootPos.X, rootPos.Y)
                        local hV = Vector2.new(headPos.X, headPos.Y)
                        local lV = Vector2.new(legPos.X, legPos.Y)
                        local boxHeight = math.abs(hV.Y - lV.Y)
                        if objs.Box then
                            local w = boxHeight * 0.55
                            objs.Box.Size = Vector2.new(w, boxHeight)
                            objs.Box.Position = rV - Vector2.new(w/2, boxHeight/2)
                            objs.Box.Color = color
                            objs.Box.Transparency = 0.7
                            objs.Box.Visible = Settings.ESPBox
                        end
                        if objs.Name then
                            objs.Name.Text = plr.Name
                            objs.Name.Position = Vector2.new(hV.X, hV.Y - 30)
                            objs.Name.Visible = Settings.ESPName
                        end
                        if objs.Health then
                            objs.Health.Text = math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
                            objs.Health.Position = Vector2.new(hV.X, hV.Y - 15)
                            local perc = hum.Health/hum.MaxHealth
                            objs.Health.Color = Color3.new(1-perc, perc, 0)
                            objs.Health.Visible = Settings.ESPHealth
                        end
                        if objs.HealthBar then
                            local w = boxHeight * 0.1
                            local bx = rV.X - boxHeight*0.3 - w - 2
                            local by = rV.Y - boxHeight/2
                            objs.HealthBar.Size = Vector2.new(w, boxHeight)
                            objs.HealthBar.Position = Vector2.new(bx, by)
                            local perc = hum.Health/hum.MaxHealth
                            objs.HealthBar.Color = Color3.new(1-perc, perc, 0)
                            objs.HealthBar.Visible = Settings.ESPHealthBar
                        end
                        if objs.Distance then
                            local dist = (myRoot.Position - root.Position).Magnitude
                            objs.Distance.Text = math.floor(dist).."m"
                            objs.Distance.Position = Vector2.new(rV.X, rV.Y + 20)
                            objs.Distance.Visible = Settings.ESPDistance
                        end
                    else
                        for _,obj in pairs(objs) do if obj and obj.Visible~=nil then obj.Visible=false end end
                    end
                else
                    for _,obj in pairs(objs) do if obj and obj.Visible~=nil then obj.Visible=false end end
                end
            else
                for _,obj in pairs(objs) do if obj and obj.Visible~=nil then obj.Visible=false end end
            end
        end
    end
end

