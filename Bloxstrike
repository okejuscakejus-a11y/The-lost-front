local function handleAction(actionName, inputState, inputObject)
    if inputState ~= Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
    if not spawned or not anims.eq or not isAlive() then return Enum.ContextActionResult.Pass end

    if actionName == ACTION_INSPECT then
        if (anims.eq and anims.eq.IsPlaying) or inspecting or swinging then return Enum.ContextActionResult.Pass end
        inspecting = true
        if anims.id then anims.id:Stop() end
        anims.ins:Play()
        anims.ins.Stopped:Once(function() inspecting = false end)
    elseif actionName == ACTION_ATTACK then
        local currentTime = os.clock()
        if (anims.eq and anims.eq.IsPlaying) or (currentTime - lastAtk < ATTACK_COOLDOWN) then return Enum.ContextActionResult.Pass end
        lastAtk = currentTime
        if inspecting then
            inspecting = false
            if anims.ins then anims.ins:Stop() end
        end
        swinging = true
        if anims.id then anims.id:Stop() end
        local animsList = {anims.hs, anims.s1, anims.s2}
        local chosenAnim = animsList[math.random(1, 3)]
        local soundFolder = (chosenAnim == anims.hs and "HitOne") or (chosenAnim == anims.s1 and "HitTwo") or "HitThree"
        chosenAnim:Play()
        local s = playSound(soundFolder, "1")
        if s then s.Volume = 5 end
        chosenAnim.Stopped:Once(function() swinging = false end)
    end
    return Enum.ContextActionResult.Pass
end

