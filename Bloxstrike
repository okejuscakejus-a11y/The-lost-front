        bg.Size = UDim2.new(1,0,0,6); bg.Position = UDim2.new(0,0,0,20); bg.BackgroundColor3 = Color3.fromRGB(40,35,40); bg.BorderSizePixel = 0
        Instance.new("UICorner", bg).CornerRadius = UDim.new(0,3)
        local fill = Instance.new("Frame", bg)
        fill.Size = UDim2.new((Settings[var]-min)/(max-min),0,1,0); fill.BackgroundColor3 = Color3.fromRGB(200,60,80); fill.BorderSizePixel = 0
        Instance.new("UICorner", fill).CornerRadius = UDim.new(0,3)
        local drag = Instance.new("TextButton", bg)
        drag.Size = UDim2.new(1,0,1,0); drag.BackgroundTransparency = 1; drag.Text = ""
        local valLbl = Instance.new("TextLabel", fr)
        valLbl.Size = UDim2.new(0,35,0,16); valLbl.Position = UDim2.new(1,-40,0,16); valLbl.BackgroundTransparency = 1; valLbl.Text = tostring(Settings[var]); valLbl.TextColor3 = Color3.new(1,1,1); valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 11
        drag.MouseButton1Down:Connect(function()
            local conn
            conn = RunService.Heartbeat:Connect(function()
                local mp = UserInputService:GetMouseLocation()
                local rel = math.clamp((mp.X - bg.AbsolutePosition.X)/bg.AbsoluteSize.X, 0, 1)
                local val = min + rel*(max-min)
                if not isFloat then val = math.floor(val) end
                if isFloat then val = math.floor(val*10)/10 end
                Settings[var] = val
                lbl.Text = txt..": "..tostring(val)
                valLbl.Text = tostring(val)
                fill.Size = UDim2.new(rel,0,1,0)
                if var=="FOV" and FOVCircle then FOVCircle.Radius = val
                elseif var=="CameraFOV" then Camera.FieldOfView = val
                elseif var=="ChamsTransparency" then UpdateChams()
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then conn:Disconnect() end
            end)
        end)
        yPos = yPos + 35
    end

