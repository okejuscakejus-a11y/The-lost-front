        attachAsset(ctGloves, "Right Arm", "Right Arm", "Glove", CFrame.new(0, 0, -1.5))
    end

    local aC = vm:FindFirstChildOfClass("AnimationController") or vm:FindFirstChildOfClass("Animator")
    local atr = aC:FindFirstChildWhichIsA("Animator") or aC
    local aF = ReplicatedStorage.Assets.WeaponAnimations:WaitForChild(Settings.SelectedKnife):WaitForChild("CameraAnimations")

    anims.eq = atr:LoadAnimation(aF:WaitForChild("Equip"))
    anims.id = atr:LoadAnimation(aF:WaitForChild("Idle"))
    anims.ins = atr:LoadAnimation(aF:WaitForChild("Inspect"))
    anims.hs = atr:LoadAnimation(aF:WaitForChild("Heavy Swing"))
    anims.s1 = atr:LoadAnimation(aF:WaitForChild("Swing1"))
    anims.s2 = atr:LoadAnimation(aF:WaitForChild("Swing2"))

    vm:SetPrimaryPartCFrame(Camera.CFrame * CFrame.new(0, -1.5, 5))
    TweenService:Create(vm.PrimaryPart, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        CFrame = Camera.CFrame * knifeOffset
    }):Play()

    anims.eq:Play()
    playSound("Equip", "1")

    ContextActionService:BindAction(ACTION_INSPECT, handleAction, false, Enum.KeyCode.F)
    ContextActionService:BindAction(ACTION_ATTACK, handleAction, false, Enum.UserInputType.MouseButton1)
end

