function GetClosestTarget()
    local closest, shortest = nil, Settings.FOV
    local myPos = Camera.CFrame.Position
    for _,p in ipairs(Players:GetPlayers()) do
        if (Settings.TeamCheck and IsEnemy(p)) or (not Settings.TeamCheck and p ~= LocalPlayer) then
            if p.Character then
                local hum = p.Character:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health>0 then
                    local part = p.Character:FindFirstChild(Settings.AimPart) or p.Character:FindFirstChild("Head") or p.Character:FindFirstChild("Torso")
                    if part then
                        local pos, vis = Camera:WorldToViewportPoint(part.Position)
                        if vis then
                            local wallCheckPassed = true
                            if Settings.WallCheck then
                                local ray = Ray.new(myPos, (part.Position - myPos).Unit * (myPos - part.Position).Magnitude)
                                local hit = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character, Camera})
                                if hit and not hit:IsDescendantOf(p.Character) then wallCheckPassed = false end
                            end
                            if wallCheckPassed then
                                local dist = (Vector2.new(pos.X,pos.Y)-ScreenCenter).Magnitude
                                if dist < shortest then
                                    shortest, closest = dist, part
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return closest
end

local function DoAim()
    if not Settings.AimEnabled then return end
    if not Settings.AimAlways and not IsKeyDown(Settings.AimKey) then return end
    local now = tick()
    if now - aimLastCall < AIM_COOLDOWN then return end
    aimLastCall = now
    local target = GetClosestTarget()
    if target then
        local pos = Camera:WorldToViewportPoint(target.Position)
        local targetPos = Vector2.new(pos.X, pos.Y)
        local delta = targetPos - ScreenCenter
        if delta.Magnitude < 2 then return end
        local smoothFactor = math.max(1, Settings.Smoothness)
        local moveX = delta.X / smoothFactor
        local moveY = delta.Y / smoothFactor
        moveX = math.clamp(moveX, -40, 40)
        moveY = math.clamp(moveY, -40, 40)
        mousemoverel(moveX, moveY)
    end
end

