local function ShouldApplyRainbow(obj)
    if not obj:IsA("BasePart") then return false end
    if table.find(RainbowBlacklisted, obj.Name) then return false end
    if LocalPlayer.Character and obj:IsDescendantOf(LocalPlayer.Character) then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") and obj:IsDescendantOf(tool) then
                return true
            end
        end
        return false
    end
    return true
end

local function ApplyRainbowEffect(O)
    if ShouldApplyRainbow(O) then
        task.spawn(function()
            while O and O.Parent do
                O.Color = Color3.fromHSV((tick() % 5) / 5, 1, 1)
                O.Transparency = 0.8
                O.Material = Enum.Material.ForceField
                task.wait()
            end
        end)
    end
end

local function StartRainbowGun()
    if Settings.RainbowGun then
        if RainbowGunConn then RainbowGunConn:Disconnect() end
        for _, v in ipairs(Camera:GetDescendants()) do
            ApplyRainbowEffect(v)
        end
        RainbowGunConn = Camera.DescendantAdded:Connect(ApplyRainbowEffect)
    else
        if RainbowGunConn then
            RainbowGunConn:Disconnect()
            RainbowGunConn = nil
        end
    end
end

